{
  "name": "oc-mirror-web-app",
  "version": "4.0",
  "description": "Web application for OpenShift Container Platform mirroring operations using oc-mirror v2",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yakovbeder/oc-mirror-web-app.git"
  },
  "author": "Yakov Beder",
  "keywords": [
    "openshift",
    "oc-mirror",
    "mirroring",
    "operators",
    "disconnected"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run server\"",
    "start": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "tsx watch server/index.ts",
    "server:build": "tsc -p server/tsconfig.json",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx} --fix",
    "format": "prettier --write src/**/*.{ts,tsx,css}",
    "clean": "rm -rf dist node_modules package-lock.json",
    "reinstall": "npm run clean && npm install"
  },
  "dependencies": {
    "@patternfly/patternfly": "^6",
    "@patternfly/react-core": "^6",
    "@patternfly/react-icons": "^6",
    "@patternfly/react-table": "^6",
    "axios": "^1.7.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "yaml": "^2.4.1",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "multer": "^2.0.0-rc.3",
    "node-cron": "^3.0.3",
    "uuid": "^11.0.1",
    "compression": "^1.7.4",
    "tar": "^6.2.0",
    "archiver": "^6.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/express": "^5",
    "@types/cors": "^2",
    "@types/compression": "^1",
    "@types/uuid": "^10",
    "@types/node": "^22",
    "@types/archiver": "^6",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4",
    "typescript": "^5.6.0",
    "vite": "^6"
  },
  "proxy": "http://localhost:3001",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  }
}
